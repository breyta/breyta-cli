#!/usr/bin/env python3
"""Summarize Breyta authoring-session command efficiency.

Input can be Codex/session JSONL or a plain copied command log. The parser is
best-effort by design; it favors stable aggregate signals over exact replay.
"""

from __future__ import annotations

import argparse
import json
import re
import sys
from collections import Counter
from pathlib import Path
from typing import Any


COMMAND_KEYS = ("command", "cmd", "args", "argv")


def flatten_strings(value: Any) -> list[str]:
    if isinstance(value, str):
        return [value]
    if isinstance(value, list):
        out: list[str] = []
        for item in value:
            out.extend(flatten_strings(item))
        return out
    if isinstance(value, dict):
        out = []
        for item in value.values():
            out.extend(flatten_strings(item))
        return out
    return []


def extract_command(obj: Any) -> str | None:
    if isinstance(obj, dict):
        for key in COMMAND_KEYS:
            value = obj.get(key)
            if isinstance(value, str) and "breyta " in value:
                return value.strip()
            if isinstance(value, list) and value and value[0] == "breyta":
                return " ".join(str(part) for part in value).strip()
        for value in obj.values():
            nested = extract_command(value)
            if nested:
                return nested
    return None


def parse_lines(path: Path) -> tuple[list[str], int]:
    commands: list[str] = []
    output_chars = 0
    command_line = re.compile(r"\bbreyta\s+[^\r\n]+")

    for raw in path.read_text(encoding="utf-8", errors="replace").splitlines():
        line = raw.strip()
        if not line:
            output_chars += len(raw)
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            obj = None
        if obj is not None:
            cmd = extract_command(obj)
            if cmd:
                commands.append(cmd)
            output_chars += sum(len(s) for s in flatten_strings(obj))
            continue
        output_chars += len(raw)
        match = command_line.search(line)
        if match:
            commands.append(match.group(0).strip())

    return commands, output_chars


TARGET_FLAG = re.compile(r"--target(?:=|\s+)(\S+)")
BROAD_LIST_LIMIT_FLAG = re.compile(r"--limit(?:=|\s+)(50|100|\d{3,})\b")


def target_value(command: str) -> str:
    match = TARGET_FLAG.search(command)
    if not match:
        return ""
    return match.group(1).strip("\"'").lower()


def analyze(commands: list[str], output_chars: int) -> dict[str, Any]:
    counts = Counter(commands)
    docs_reads = [c for c in commands if " docs show " in f" {c} "]
    docs_searches = [c for c in commands if " docs find " in f" {c} "]
    full_pulls = [
        c
        for c in commands
        if " flows pull " in f" {c} " or "--full" in c or " --pretty" in c
    ]
    broad_lists = [
        c
        for c in commands
        if " flows list " in f" {c} " and BROAD_LIST_LIMIT_FLAG.search(c)
    ]
    workspace_searches = [c for c in commands if " flows workspace search " in f" {c} "]
    workspace_examples = [
        c for c in commands if " flows workspace examples step " in f" {c} "
    ]
    configure_checks = [c for c in commands if " flows configure check " in f" {c} "]
    draft_runs = [
        c
        for c in commands
        if (" flows run " in f" {c} " or " runs start " in f" {c} ")
        and (target_value(c) in ("", "draft"))
        and ("--target draft" in c or "--target=draft" in c or "--wait" in c)
    ]

    return {
        "commands": len(commands),
        "uniqueCommands": len(counts),
        "duplicateCommands": {
            cmd: count for cmd, count in counts.items() if count > 1
        },
        "outputChars": output_chars,
        "docsFinds": len(docs_searches),
        "docsShows": len(docs_reads),
        "fullOrPrettyReads": len(full_pulls),
        "broadFlowLists": len(broad_lists),
        "workspaceSearches": len(workspace_searches),
        "workspaceExampleReads": len(workspace_examples),
        "configureChecks": len(configure_checks),
        "draftRuns": len(draft_runs),
    }


def print_markdown(summary: dict[str, Any]) -> None:
    print("# Authoring Session Efficiency")
    print()
    for key in (
        "commands",
        "uniqueCommands",
        "outputChars",
        "docsFinds",
        "docsShows",
        "fullOrPrettyReads",
        "broadFlowLists",
        "workspaceSearches",
        "workspaceExampleReads",
        "configureChecks",
        "draftRuns",
    ):
        print(f"- {key}: {summary[key]}")
    duplicates = summary["duplicateCommands"]
    print(f"- duplicateCommands: {len(duplicates)}")
    if duplicates:
        print()
        print("## Duplicates")
        for cmd, count in sorted(duplicates.items(), key=lambda item: (-item[1], item[0])):
            print(f"- {count}x `{cmd}`")


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("session", help="Path to Codex/session JSONL or command log")
    parser.add_argument("--json", action="store_true", help="Print JSON instead of markdown")
    args = parser.parse_args(argv)

    path = Path(args.session)
    if not path.exists():
        print(f"session not found: {path}", file=sys.stderr)
        return 2

    commands, output_chars = parse_lines(path)
    summary = analyze(commands, output_chars)
    if args.json:
        print(json.dumps(summary, indent=2, sort_keys=True))
    else:
        print_markdown(summary)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
